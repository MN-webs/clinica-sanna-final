{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mkdir -p target/dependency && curl -L https://repo1.maven.org/maven2/com/heroku/webapp-runner/9.0.52.1/webapp-runner-9.0.52.1.jar -o target/dependency/webapp-runner.jar"
  },
  "deploy": {
    "startCommand": "java -jar target/dependency/webapp-runner.jar --port $PORT ROOT.war",
    "restartPolicyType": "ON_FAILURE"
  }
}
